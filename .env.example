# Copy to .env.local (dev) or configure these in your deploy platform.
# Never commit the real .env / .env.local — see .gitignore.

# --- planoo's own database (MySQL) ---
# Auth.js tables (User/Account/Session) + SchemaSnapshot + Link + AgentApiKey.
DATABASE_URL="mysql://user:password@localhost:3306/planoo"

# --- Auth.js ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-real-secret"

# --- Figma OAuth app (create at https://www.figma.com/developers/apps) ---
FIGMA_CLIENT_ID=""
FIGMA_CLIENT_SECRET=""

# --- SchemaSnapshot encryption (AES-256-GCM key material, see src/lib/crypto.ts) ---
# Generate with: openssl rand -base64 32
SNAPSHOT_ENCRYPTION_KEY="replace-with-a-real-secret"

# --- Used only by scripts/agent.ts, run on the CUSTOMER's machine, never here ---
# PLANOO_API_KEY="generated from the planoo dashboard, one per agent install"
# AGENT_DATABASE_URL="mysql://user:password@customer-host:3306/customer_db"
# PLANOO_API_URL="https://planoo.xyz"
