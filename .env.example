# Copy to .env.local (dev) or configure these in your deploy platform.
# Never commit the real .env / .env.local — see .gitignore.

# --- planoo's own database (MySQL) ---
# Auth.js tables (User/Account/Session) + SchemaSnapshot + Link + AgentApiKey.
DATABASE_URL="mysql://user:password@localhost:3306/planoo"

# --- Auth.js ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-real-secret"

# --- Google OAuth (sign-in / account creation — create at https://console.cloud.google.com/apis/credentials) ---
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (dev) or https://your-domain/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Figma OAuth app (create at https://www.figma.com/developers/apps) ---
# NOT a sign-in provider — connected from inside the dashboard by an already
# signed-in user (see src/app/api/figma/connect). Redirect URI:
# http://localhost:3000/api/figma/callback (dev) or https://your-domain/api/figma/callback (prod)
# IMPORTANT: in the app's settings, under Scopes, enable BOTH
# "file_content:read" and "current_user:read" — without both enabled on the
# app itself, the OAuth request 400s with "Invalid scopes for app" even
# though the code requests the right scopes (this is what happened before
# the fix; the old "file_read" scope name Figma used to use is deprecated).
FIGMA_CLIENT_ID=""
FIGMA_CLIENT_SECRET=""

# --- SchemaSnapshot encryption (AES-256-GCM key material, see src/lib/crypto.ts) ---
# Generate with: openssl rand -base64 32
SNAPSHOT_ENCRYPTION_KEY="replace-with-a-real-secret"

# --- Lemon Squeezy (billing — create at https://app.lemonsqueezy.com/settings/api) ---
LEMONSQUEEZY_API_KEY=""
# Settings > Webhooks > Signing secret, once you create the webhook pointing at /api/lemonsqueezy/webhook
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_STORE_ID=""
# Variant IDs for each paid plan (Products > select product > variant) — see src/lib/pricing.ts
LEMONSQUEEZY_SOLO_VARIANT_ID=""
LEMONSQUEEZY_TEAM_VARIANT_ID=""

# --- Used only by scripts/agent.ts, run on the CUSTOMER's machine, never here ---
# PLANOO_API_KEY="generated from the planoo dashboard, one per agent install"
# AGENT_DATABASE_URL="mysql://user:password@customer-host:3306/customer_db"
# PLANOO_API_URL="https://planoo.xyz"
