generator client {
  provider = "prisma-client-js"
}

// Prisma 7: the connection URL no longer lives here — it's supplied via the
// driver adapter passed to PrismaClient (see src/lib/prisma.ts) and to
// Prisma Migrate via prisma.config.ts.
datasource db {
  provider = "mysql"
}

// --- Auth.js standard schema (@auth/prisma-adapter) ---
// https://authjs.dev/getting-started/adapters/prisma

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Free until a Lemon Squeezy subscription (see Subscription below) says
  // otherwise. Denormalized onto User for cheap reads everywhere access
  // needs gating — the Subscription row is the source of truth and updates
  // this via the Lemon Squeezy webhook handler.
  plan          PlanTier  @default(free)

  accounts        Account[]
  sessions        Session[]
  schemaSnapshots SchemaSnapshot[]
  links           Link[]
  agentApiKeys    AgentApiKey[]
  subscription    Subscription?
  designedTables  DesignedTable[]
  projects        Project[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- planoo domain models ---

enum SnapshotSource {
  figma
  // Pushed by scripts/agent.ts from a live DB read — now an optional/
  // advanced path (see DesignedTable below for the default one).
  mysql
}

// A single read of either the Figma file structure or a customer's DB schema.
// Retention: only the last 2 snapshots per (userId, projectId, source) are
// kept — the current one and the previous one, which is all drift-detection
// needs. Older rows are deleted by lib/snapshot.ts whenever a new one is
// created.
model SchemaSnapshot {
  id        String         @id @default(cuid())
  userId    String
  // Null for agent-pushed ("mysql") snapshots — scripts/agent.ts has no
  // concept of a project, it's a single API key tied to a user (see TODOS.md
  // "advanced path"). Always set for "figma" snapshots, one board per
  // project (see /api/recheck).
  projectId String?
  source    SnapshotSource
  // Encrypted at rest (application-level encryption before write — see lib/crypto.ts).
  // Contains the raw structure: Figma node tree or MySQL table/column list.
  payload   String         @db.LongText
  createdAt DateTime       @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  linksLastSeenHere Link[]

  @@index([userId, projectId, source, createdAt])
}

enum LinkState {
  suggested
  confirmed
  stale
  broken
  rejected
}

// One proposed or confirmed mapping between a Figma UI element and a DB column.
//
// State machine:
//   suggested  --user confirms--> confirmed
//   suggested  --user rejects-->  rejected   (never re-suggested for the same pair)
//   confirmed  --source renamed--> stale     (new suggestion offered, re-confirm to clear)
//   confirmed  --source deleted--> broken    (stays until manually resolved)
//
// Rerun scope (decided in /plan-eng-review): re-matching on "recheck" only
// touches links NOT in `confirmed` state. Confirmed links are never silently
// overwritten by a new higher-confidence suggestion for the same pair.
//
// Deliberately belongs to the USER, not a SchemaSnapshot: SchemaSnapshot
// retention prunes down to the last 2 rows (see lib/snapshot.ts), and a
// `confirmed` Link must survive that pruning — it's the whole point of the
// state machine. `lastSeenSnapshotId` is informational only (onDelete:
// SetNull), never something a Link's existence depends on.
model Link {
  id                 String    @id @default(cuid())
  userId             String
  projectId          String?
  figmaNodeId        String
  dbTableName        String
  dbColumnName       String
  confidence         Float
  state              LinkState @default(suggested)
  lastSeenSnapshotId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project          Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lastSeenSnapshot SchemaSnapshot? @relation(fields: [lastSeenSnapshotId], references: [id], onDelete: SetNull)

  @@unique([userId, figmaNodeId, dbTableName, dbColumnName])
  @@index([userId, state])
  @@index([projectId])
}

// A table the user designed directly in planoo's schema builder — the
// default, friction-free way to get a DB schema into planoo (added after
// live usage showed the agent-connect step was the biggest onboarding
// drop-off point; scripts/agent.ts remains available as an optional
// "sync from a real live DB" path, see TODOS.md). No snapshot/retention
// concept needed here unlike SchemaSnapshot — this data doesn't come from
// an external source that can drift out from under us; editing IS the
// update. /api/recheck reads these fresh every time.
model DesignedTable {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  name      String
  // Canvas position (blueprint drag-and-drop layout). Defaults to 0,0 for
  // rows created before the canvas existed — the client auto-arranges any
  // tables it finds stacked at the origin on first render.
  posX      Float    @default(0)
  posY      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  columns DesignedColumn[]

  @@unique([userId, name])
  @@index([projectId])
}

model DesignedColumn {
  id               String  @id @default(cuid())
  tableId          String
  name             String
  // Free-text SQL type ("varchar(255)", "int", "text", ...) rather than an
  // enum — v0 doesn't need to validate SQL type syntax, just pass it
  // through to matching (name/type similarity, see lib/matcher) and to the
  // .sql export (lib/schema-export.ts).
  dataType         String
  nullable         Boolean @default(true)
  isPrimaryKey     Boolean @default(false)
  isForeignKey     Boolean @default(false)
  referencesTable  String?
  referencesColumn String?
  order            Int     @default(0)

  table DesignedTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, name])
}

// --- Project & Roadmap models (dashboard restructuring) ---

// A project groups together a Figma file, a DB schema (designed tables), and
// a roadmap. This is the multi-project data model called out in TODOS.md P1.
// projectId is still optional (nullable) on DesignedTable/Link/SchemaSnapshot
// so existing pre-restructuring data isn't broken — new projects created
// from the dashboard always set it, and /api/recheck (see that route) is the
// one place all of these are threaded together per-project.
model Project {
  id           String   @id @default(cuid())
  userId       String
  name         String
  description  String?  @db.Text
  // The Figma file THIS project tracks — replaced User.figmaFileKey (single
  // file per account) when multi-project support landed. Set from the
  // create-project modal or the settings panel; read by /api/recheck.
  figmaFileKey String?
  // Free-text URL, not validated beyond trimming — just a reference link for
  // the team, not something planoo reads or clones.
  githubRepo   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  designedTables    DesignedTable[]
  links             Link[]
  roadmapItems      RoadmapItem[]
  roadmapColumns    RoadmapColumn[]
  schemaSnapshots   SchemaSnapshot[]
  costEstimateInput CostEstimateInput?

  @@unique([userId, name])
}

// A Trello-style list. Board columns used to be a fixed 3-value enum
// (todo/in_progress/done) on RoadmapItem directly — replaced by this so
// users can add/rename/reorder their own lists instead of being stuck with
// exactly those three. See migration 20260719_* for how existing
// enum-based data was backfilled into real columns instead of being lost.
model RoadmapColumn {
  id        String   @id @default(cuid())
  projectId String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   RoadmapItem[]

  @@index([projectId, order])
}

model RoadmapItem {
  id          String    @id @default(cuid())
  projectId   String
  columnId    String
  title       String
  description String?   @db.Text
  // Free-text, not a fixed enum — a small set of presets would need its own
  // management UI for a feature this size; the card just shows whatever
  // string is set as a badge.
  label       String?
  dueDate     DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column   RoadmapColumn    @relation(fields: [columnId], references: [id], onDelete: Cascade)
  comments RoadmapComment[]

  @@index([projectId, columnId])
}

// No author field — projects are single-owner (no team-member model exists
// yet, see TODOS.md "Team" plan), so there's only ever one possible author.
model RoadmapComment {
  id            String   @id @default(cuid())
  roadmapItemId String
  text          String   @db.Text
  createdAt     DateTime @default(now())

  roadmapItem RoadmapItem @relation(fields: [roadmapItemId], references: [id], onDelete: Cascade)

  @@index([roadmapItemId, createdAt])
}

// Single-use key a user generates from the web UI and passes to
// `scripts/agent.ts` (via PLANOO_API_KEY) so the agent can attribute its
// schema push to the right account without doing OAuth itself.
model AgentApiKey {
  id         String    @id @default(cuid())
  userId     String
  // Store only a hash — never the raw key — same principle as password storage.
  keyHash    String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Persisted, per-project cost-simulator inputs — deliberately the ONLY
// thing this feature persists (v0: "build fast, validate via real usage").
// One row per project (upsert on save): remembers the user's last
// assumptions across sessions and doubles as a queryable usage signal (row
// existence / updatedAt recency) with no dedicated analytics infra needed.
// The computed cost breakdown itself is NEVER stored here — it's cheap to
// recompute from these inputs + the live DesignedTable/Column schema + the
// hardcoded preset rate table (lib/cost-presets.ts), so schema edits and
// rate-table tweaks show up immediately with no cache-invalidation or
// backfill concern. No history of past calculations is kept (see TODOS.md
// — explicitly deferred until there's demand for cost-trend tracking).
model CostEstimateInput {
  id        String @id @default(cuid())
  projectId String @unique

  // Which hardcoded reference stack (see lib/cost-presets.ts) the estimate
  // is based on — free-text id, not an enum, so adding/renaming presets
  // never needs a migration (same reasoning as DesignedColumn.dataType).
  presetId            String
  monthlyActiveUsers  Int    @default(0)
  // Only feeds the qualitative "bottleneck" flags, never multiplied
  // directly into the dollar total — see lib/cost-estimate.ts for why
  // request-based billing was deliberately folded into a single blended
  // per-MAU rate instead of a second rate that would need its own
  // sourcing/defending.
  avgRequestsPerUser  Int    @default(50)
  // Applied uniformly to every DesignedTable when deriving DB storage —
  // the v0 simplification instead of a per-table row-count input grid.
  assumedRowsPerTable Int    @default(10000)
  // GB not represented by the designed schema at all (file/blob uploads,
  // exports, etc.) — added on top of the schema-derived DB storage rather
  // than guessed from column names.
  manualFileStorageGb Float  @default(0)
  egressGbPerMonth    Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum PlanTier {
  free
  solo
  team
}

enum SubscriptionStatus {
  on_trial
  active
  paused
  past_due
  unpaid
  cancelled
  expired
}

// Mirrors a Lemon Squeezy subscription. One per user (v0 doesn't support a
// user having multiple concurrent subscriptions) — created/updated/deleted
// entirely from src/app/api/lemonsqueezy/webhook, never written by the app
// directly. User.plan is denormalized from this row's `status`/`variantId`
// for cheap reads; this table is the reconciliation source of truth.
model Subscription {
  id                         String             @id @default(cuid())
  userId                     String             @unique
  plan                       PlanTier
  status                     SubscriptionStatus
  lemonSqueezySubscriptionId String             @unique
  lemonSqueezyCustomerId     String
  lemonSqueezyVariantId      String
  renewsAt                   DateTime?
  endsAt                     DateTime?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
