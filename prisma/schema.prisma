generator client {
  provider = "prisma-client-js"
}

// Prisma 7: the connection URL no longer lives here — it's supplied via the
// driver adapter passed to PrismaClient (see src/lib/prisma.ts) and to
// Prisma Migrate via prisma.config.ts.
datasource db {
  provider = "mysql"
}

// --- Auth.js standard schema (@auth/prisma-adapter) ---
// https://authjs.dev/getting-started/adapters/prisma

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // The Figma file this account tracks. Set once from the canvas UI ("connect
  // a Figma file"); v0 is single-file-per-account (see design doc "NOT in
  // scope": multi-project support is deferred).
  figmaFileKey  String?
  // Free until a Lemon Squeezy subscription (see Subscription below) says
  // otherwise. Denormalized onto User for cheap reads everywhere access
  // needs gating — the Subscription row is the source of truth and updates
  // this via the Lemon Squeezy webhook handler.
  plan          PlanTier  @default(free)

  accounts        Account[]
  sessions        Session[]
  schemaSnapshots SchemaSnapshot[]
  links           Link[]
  agentApiKeys    AgentApiKey[]
  subscription    Subscription?
  designedTables  DesignedTable[]
  projects        Project[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- planoo domain models ---

enum SnapshotSource {
  figma
  // Pushed by scripts/agent.ts from a live DB read — now an optional/
  // advanced path (see DesignedTable below for the default one).
  mysql
}

// A single read of either the Figma file structure or a customer's DB schema.
// Retention: only the last 2 snapshots per (userId, source) are kept — the
// current one and the previous one, which is all drift-detection needs.
// Older rows are deleted by lib/snapshot.ts whenever a new one is created.
model SchemaSnapshot {
  id        String         @id @default(cuid())
  userId    String
  source    SnapshotSource
  // Encrypted at rest (application-level encryption before write — see lib/crypto.ts).
  // Contains the raw structure: Figma node tree or MySQL table/column list.
  payload   String         @db.LongText
  createdAt DateTime       @default(now())

  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  linksLastSeenHere Link[]

  @@index([userId, source, createdAt])
}

enum LinkState {
  suggested
  confirmed
  stale
  broken
  rejected
}

// One proposed or confirmed mapping between a Figma UI element and a DB column.
//
// State machine:
//   suggested  --user confirms--> confirmed
//   suggested  --user rejects-->  rejected   (never re-suggested for the same pair)
//   confirmed  --source renamed--> stale     (new suggestion offered, re-confirm to clear)
//   confirmed  --source deleted--> broken    (stays until manually resolved)
//
// Rerun scope (decided in /plan-eng-review): re-matching on "recheck" only
// touches links NOT in `confirmed` state. Confirmed links are never silently
// overwritten by a new higher-confidence suggestion for the same pair.
//
// Deliberately belongs to the USER, not a SchemaSnapshot: SchemaSnapshot
// retention prunes down to the last 2 rows (see lib/snapshot.ts), and a
// `confirmed` Link must survive that pruning — it's the whole point of the
// state machine. `lastSeenSnapshotId` is informational only (onDelete:
// SetNull), never something a Link's existence depends on.
model Link {
  id                 String    @id @default(cuid())
  userId             String
  projectId          String?
  figmaNodeId        String
  dbTableName        String
  dbColumnName       String
  confidence         Float
  state              LinkState @default(suggested)
  lastSeenSnapshotId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project          Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lastSeenSnapshot SchemaSnapshot? @relation(fields: [lastSeenSnapshotId], references: [id], onDelete: SetNull)

  @@unique([userId, figmaNodeId, dbTableName, dbColumnName])
  @@index([userId, state])
}

// A table the user designed directly in planoo's schema builder — the
// default, friction-free way to get a DB schema into planoo (added after
// live usage showed the agent-connect step was the biggest onboarding
// drop-off point; scripts/agent.ts remains available as an optional
// "sync from a real live DB" path, see TODOS.md). No snapshot/retention
// concept needed here unlike SchemaSnapshot — this data doesn't come from
// an external source that can drift out from under us; editing IS the
// update. /api/recheck reads these fresh every time.
model DesignedTable {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  name      String
  // Canvas position (blueprint drag-and-drop layout). Defaults to 0,0 for
  // rows created before the canvas existed — the client auto-arranges any
  // tables it finds stacked at the origin on first render.
  posX      Float    @default(0)
  posY      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  columns DesignedColumn[]

  @@unique([userId, name])
}

model DesignedColumn {
  id               String  @id @default(cuid())
  tableId          String
  name             String
  // Free-text SQL type ("varchar(255)", "int", "text", ...) rather than an
  // enum — v0 doesn't need to validate SQL type syntax, just pass it
  // through to matching (name/type similarity, see lib/matcher) and to the
  // .sql export (lib/schema-export.ts).
  dataType         String
  nullable         Boolean @default(true)
  isPrimaryKey     Boolean @default(false)
  isForeignKey     Boolean @default(false)
  referencesTable  String?
  referencesColumn String?
  order            Int     @default(0)

  table DesignedTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, name])
}

// --- Project & Roadmap models (dashboard restructuring) ---

// A project groups together a Figma file, a DB schema (designed tables), and
// a roadmap. This is the multi-project data model called out in TODOS.md P1.
// For v0 of this restructure, projectId is optional on DesignedTable/Link
// so existing data isn't broken — new projects created from the dashboard
// always set it.
model Project {
  id           String   @id @default(cuid())
  userId       String
  name         String
  description  String?  @db.Text
  figmaFileKey String?
  // Free-text URL, not validated beyond trimming — just a reference link for
  // the team, not something planoo reads or clones.
  githubRepo   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  designedTables DesignedTable[]
  links          Link[]
  roadmapItems   RoadmapItem[]

  @@unique([userId, name])
}

enum RoadmapStatus {
  todo
  in_progress
  done
}

model RoadmapItem {
  id          String        @id @default(cuid())
  projectId   String
  title       String
  description String?       @db.Text
  // Free-text, not a fixed enum — a small set of presets would need its own
  // management UI for a feature this size; the card just shows whatever
  // string is set as a badge.
  label       String?
  dueDate     DateTime?
  status      RoadmapStatus @default(todo)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments RoadmapComment[]

  @@index([projectId, status])
}

// No author field — projects are single-owner (no team-member model exists
// yet, see TODOS.md "Team" plan), so there's only ever one possible author.
model RoadmapComment {
  id            String   @id @default(cuid())
  roadmapItemId String
  text          String   @db.Text
  createdAt     DateTime @default(now())

  roadmapItem RoadmapItem @relation(fields: [roadmapItemId], references: [id], onDelete: Cascade)

  @@index([roadmapItemId, createdAt])
}

// Single-use key a user generates from the web UI and passes to
// `scripts/agent.ts` (via PLANOO_API_KEY) so the agent can attribute its
// schema push to the right account without doing OAuth itself.
model AgentApiKey {
  id         String    @id @default(cuid())
  userId     String
  // Store only a hash — never the raw key — same principle as password storage.
  keyHash    String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PlanTier {
  free
  solo
  team
}

enum SubscriptionStatus {
  on_trial
  active
  paused
  past_due
  unpaid
  cancelled
  expired
}

// Mirrors a Lemon Squeezy subscription. One per user (v0 doesn't support a
// user having multiple concurrent subscriptions) — created/updated/deleted
// entirely from src/app/api/lemonsqueezy/webhook, never written by the app
// directly. User.plan is denormalized from this row's `status`/`variantId`
// for cheap reads; this table is the reconciliation source of truth.
model Subscription {
  id                         String             @id @default(cuid())
  userId                     String             @unique
  plan                       PlanTier
  status                     SubscriptionStatus
  lemonSqueezySubscriptionId String             @unique
  lemonSqueezyCustomerId     String
  lemonSqueezyVariantId      String
  renewsAt                   DateTime?
  endsAt                     DateTime?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
